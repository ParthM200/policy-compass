# Copy this file to .env and fill in real values for local development
# (firebase emulators:start). In production, these are set as Cloud
# Functions secrets - see README.md for the `firebase functions:secrets:set` commands.

# Google Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# Jira integration (used by the "Push to Jira" feature)
# Atlassian site URL, e.g. https://your-domain.atlassian.net
JIRA_URL=
# Project key tickets are created under, e.g. SCRUM
JIRA_PROJECT_KEY=
# Atlassian account email used to authenticate
JIRA_EMAIL=
# Atlassian API token (https://id.atlassian.com/manage-profile/security/api-tokens)
JIRA_API_TOKEN=
